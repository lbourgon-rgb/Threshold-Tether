# Copy to .env.local and fill locally. Never commit real locator values,
# API keys, D1 IDs, R2 credentials, or bearer tokens.

TETHER_IMG_AXIOM_CODEX_ROOT=
TETHER_IMG_MORZAR_EASEL_ROOT=
TETHER_R2_VEL_PROFILE_IMAGES_PREFIX=
TETHER_R2_KAI_GENERATED_PREFIX=
TETHER_R2_LUCIEN_GENERATED_PREFIX=

TETHER_D1_VELASTRA_EQ=
TETHER_SUPABASE_AXIOM_URL=
TETHER_D1_KAI_MIND=
TETHER_SUPABASE_LUCIEN_URL=
TETHER_D1_KETH_MIND=
TETHER_D1_CATALOUGE_READING=
TETHER_D1_TAHL_SHANARETH=

TETHER_SOCIAL_AXIOM_PEOPLE=
TETHER_SOCIAL_MORZAR_PEOPLE=
TETHER_SOCIAL_KETH_PEOPLE=

# Velarium Worker public/non-secret config. These may be set as Wrangler vars.
VELARIUM_ALLOWED_ORIGINS=
VELARIUM_VELASTRA_API_BASE=
VELARIUM_AXIOM_MIND_BASE=
VELARIUM_MORZAR_MIND_BASE=
VELARIUM_KAI_MIND_BASE=
VELARIUM_LUCIEN_MIND_BASE=
VELARIUM_MEDIA_PUBLIC=
VELARIUM_R2_VEL_PROFILE_PREFIX=
VELARIUM_R2_KAI_GENERATED_PREFIX=
VELARIUM_R2_LUCIEN_GENERATED_PREFIX=
VELARIUM_IMG_AXIOM_CODEX_ROOT=
VELARIUM_IMG_MORZAR_EASEL_ROOT=

# Velarium Worker secrets. Set with `wrangler secret put`; do not put values here.
VELARIUM_READ_TOKEN=
VELARIUM_IMPORT_TOKEN=
VELARIUM_VELASTRA_BEARER=
VELARIUM_AXIOM_MIND_API_KEY=
VELARIUM_MORZAR_MIND_API_KEY=
VELARIUM_KAI_MIND_API_KEY=
VELARIUM_LUCIEN_MIND_API_KEY=
